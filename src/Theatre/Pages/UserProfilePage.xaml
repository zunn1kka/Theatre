<Page x:Class="Theatre.Pages.UserProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Theatre.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="600"
      Title="UserProfilePage">

    <Grid Margin="20" Background="{StaticResource ColorBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Логин:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox Text="{Binding Login}" Grid.Row="0" Grid.Column="1" Margin="5" IsReadOnly="True"/>

        <TextBlock Text="Почта:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox Text="{Binding Email}" Grid.Row="1" Grid.Column="1" Margin="5" IsReadOnly="True"/>

        <TextBlock Text="Фото:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <Image Source="{Binding UserPhoto}" Grid.Row="2" Grid.Column="1" Margin="5" Width="100" Height="100"/>

        <Button Content="Загрузить фото" Grid.Row="3" Grid.Column="1" Margin="5" 
                Command="{Binding LoadPhotoCommand}" Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Left"/>
    </Grid>
</Page>
